# Copy this file to .env.local for local development,
# and add the same keys in your Vercel project's Environment Variables.

# --- Admin login (only you should know these) ---
ADMIN_EMAIL=you@example.com
# Generate with: npm run hash-password -- "your-strong-password"
ADMIN_PASSWORD_HASH=

# Random long string used to sign admin session tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# --- GitHub (lets the admin dashboard commit content changes for you) ---
# Personal access token (classic or fine-grained) with "Contents: Read and write"
# access on the repo below. Create at https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-portfolio-repo
GITHUB_BRANCH=main
